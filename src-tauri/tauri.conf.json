{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "translate-me",
  "version": "0.1.0",
  "identifier": "com.duino.translateme",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "translate-me",
        "width": 560,
        "height": 220,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "center": false,
        "focus": true
      },
      {
        "label": "settings",
        "title": "translate-me 设置",
        "url": "settings.html",
        "width": 460,
        "height": 560,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
