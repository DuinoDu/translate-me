# Copy to .env.signing (gitignored) and fill in. Used by scripts/build-signed.sh.

# Your Developer ID Application identity. Find the exact string with:
#   security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# ---- Notarization: choose ONE method ----

# Method A (recommended): App Store Connect API key (.p8)
#   Create at https://appstoreconnect.apple.com/access/integrations/api
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"   # Issuer ID
APPLE_API_KEY="XXXXXXXXXX"                                 # Key ID
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"

# Method B: Apple ID + app-specific password
#   App-specific password: https://account.apple.com -> Sign-In & Security
# APPLE_ID="you@example.com"
# APPLE_PASSWORD="abcd-efgh-ijkl-mnop"
# APPLE_TEAM_ID="TEAMID"
